# 环境变量配置示例

# ── Web / Docker 监听配置 ────────────────────────────────────
# 容器内应用监听地址与端口
APP_HOST=0.0.0.0
APP_PORT=8000

# Docker 端口绑定地址（如仅本机访问可改成 127.0.0.1）
WEB_BIND_IP=0.0.0.0

# Web UI 访问密码
APP_ACCESS_PASSWORD=your_secret_password

# 兼容旧命名（可不填，compose 会自动映射）
# WEBUI_HOST=0.0.0.0
# WEBUI_PORT=8000
# WEBUI_ACCESS_PASSWORD=your_secret_password

# ── 数据库 ───────────────────────────────────────────────────
# Docker 场景下默认推荐使用容器内挂载目录
# APP_DATABASE_URL=sqlite:////app/data/database.db

# 远程 PostgreSQL（如需启用）
# APP_DATABASE_URL=postgresql://user:password@host:5432/dbname
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Telegram 通知（用于 CPA 自动补货/失败通知） ───────────────
# 建议使用这组命名
# TG_BOT_TOKEN=123456789:ABCDEF_your_bot_token
# TG_CHAT_ID=123456789

# 兼容命名（代码也支持）
# TELEGRAM_BOT_TOKEN=123456789:ABCDEF_your_bot_token
# TELEGRAM_CHAT_ID=123456789
